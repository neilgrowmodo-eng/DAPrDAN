{{ 'component-rte.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .create-account-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #shopify-section-{{ section.id }} .create-account-section__grid {
    display: flex;
    /* grid-template-columns: minmax(280px, {{ section.settings.form_column_width }}px) minmax(0, 1fr); */
    gap: {{ section.settings.column_gap }}px;
    max-width: 1280px;
    align-items: flex-start;
    justify-content: center;
    margin: auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .create-account-section__card {
    background: {{ section.settings.card_background }};
    color: {{ section.settings.card_text_color }};
    border-radius: {{ section.settings.card_radius }}px;
    box-shadow: 0 16px 45px rgba(0, 0, 0, 0.12);
    padding: {{ section.settings.card_padding }}px;
    max-width: 530px;
  }

  #shopify-section-{{ section.id }} .create-account-section__form-heading {
    margin: 0 0 12px;
    color: {{ section.settings.form_heading_color }};
    font-size: {{ section.settings.form_heading_size }}px;
    line-height: 1.1;
    font-family: "Outfit", sans-serif;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .create-account-section__form-text {
    margin: 0 0 18px;
    color: {{ section.settings.form_text_color }};
    font-size: {{ section.settings.form_text_size }}px;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .create-account-section__field {
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .create-account-section__input {
    width: 100%;
    min-height: 46px;
    padding: 12px 18px;
    border: 1px solid #D0D0D0;
    border-radius: {{ section.settings.input_radius }}px;
    font-size: 16px;
    background: #fff;
    color: #121212;
  }

  #shopify-section-{{ section.id }} .create-account-section__button {
    width: 100%;
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: {{ section.settings.button_radius }}px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 16px;
    font-weight: 700;
    font-family: "Nunito Sans", sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .create-account-section__divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 18px 0 6px;
    color: {{ section.settings.divider_text_color }};
    font-size: 13px;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .create-account-section__divider::before,
  #shopify-section-{{ section.id }} .create-account-section__divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: rgba(var(--color-foreground), 0.14);
  }

  #shopify-section-{{ section.id }} .create-account-section__helper-text {
    margin: 0 0 18px;
    color: {{ section.settings.form_text_color }};
    font-size: {{ section.settings.helper_text_size }}px;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .create-account-section__social-link {
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid rgba(var(--color-foreground), 0.18);
    border-radius: {{ section.settings.social_button_radius }}px;
    background: #fff;
    color: {{ section.settings.social_button_text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .create-account-section__social-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .create-account-section__login {
    display: block;
    margin-top: 10px;
    text-align: center;
    color: {{ section.settings.login_link_color }};
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #shopify-section-{{ section.id }} .create-account-section__content {
    color: {{ section.settings.content_text_color }};
    max-width: 530px;
  }

  #shopify-section-{{ section.id }} .create-account-section__heading {
    margin: 0 0 16px;
    color: {{ section.settings.content_heading_color }};
    font-size: {{ section.settings.content_heading_size }}px;
    line-height: 1.10;
    font-family: "Outfit", sans-serif;
    font-weight: 700;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .create-account-section__body {
    max-width: 650px;
    margin: 0 0 28px;
    color: {{ section.settings.content_text_color }};
    font-size: {{ section.settings.content_body_size }}px;
    line-height: 1.65;
  }

  #shopify-section-{{ section.id }} .create-account-section__group {
    margin-top: 24px;
  }

  #shopify-section-{{ section.id }} .create-account-section__group-heading {
    margin: 0 0 14px;
    color: {{ section.settings.group_heading_color }};
    font-size: {{ section.settings.group_heading_size }}px;
    line-height: 1.25;
    font-family: "Outfit", sans-serif;
    font-weight: 600;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .create-account-section__list {
    display: grid;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .create-account-section__list-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: {{ section.settings.list_text_color }};
    font-size: {{ section.settings.list_text_size }}px;
    line-height: 1.45;
  }
/* 
  #shopify-section-{{ section.id }} .create-account-section__check {
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
    margin-top: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ section.settings.check_radius }}px;
    background: {{ section.settings.check_background }};
    color: {{ section.settings.check_color }};
    font-size: 10px;
    line-height: 1;
  } */

  #shopify-section-{{ section.id }} .create-account-section__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 20px 28px;
    margin-top: 36px;
  }

  #shopify-section-{{ section.id }} .create-account-section__logo {
    max-width: {{ section.settings.logo_max_width }}px;
    height: auto;
    display: block;
    opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} h1 {
    font-family: var(--font-heading-family);
  }

  .create-account-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    margin: 24px 0 16px;
  }

  .create-account-divider__line {
    flex: 1;
    height: 1px;
    background-color: #e5e5e5;
  }

  .create-account-divider__text {
    color: #5f6368;
    font-size: 16px;
    line-height: 1;
    font-weight: 400;
    text-transform: uppercase;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .create-account-section__grid {
      flex-direction: column;
      gap: 40px;
    }

    #shopify-section-{{ section.id }} .create-account-section__card {
      max-width: 580px;
      margin: 0 auto;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .create-account-section__content {
      text-align: {{ section.settings.mobile_text_alignment }};
    }

    #shopify-section-{{ section.id }} .create-account-section__body {
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .create-account-section__list-item {
      justify-content: {% if section.settings.mobile_text_alignment == 'center' %}center{% else %}flex-start{% endif %};
      text-align: left;
    }

    #shopify-section-{{ section.id }} .create-account-section__logos {
      justify-content: {% if section.settings.mobile_logo_alignment == 'center' %}center{% else %}flex-start{% endif %};
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .create-account-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .create-account-section__card {
      padding: {{ section.settings.card_padding | times: 0.75 | round: 0 }}px;
    }

    #shopify-section-{{ section.id }} .create-account-section__form-heading {
      font-size: {{ section.settings.form_heading_size | times: 0.82 | round: 0 }}px;
    }

    #shopify-section-{{ section.id }} .create-account-section__heading {
      font-size: {{ section.settings.content_heading_size | times: 0.8 | round: 0 }}px;
    }
  }
{%- endstyle -%}

<section class="create-account-section color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="create-account-section__grid">
      <div class="create-account-section__card" data-custom-customer-create-card>
        {%- if section.settings.form_heading != blank -%}
          <h1 class="create-account-section__form-heading">
            {{ section.settings.form_heading }}
          </h1>
        {%- endif -%}

        {%- if section.settings.form_text != blank -%}
          <div class="create-account-section__form-text rte">
            {{ section.settings.form_text }}
          </div>
        {%- endif -%}

        <form
          id="CustomCustomerCreateForm-{{ section.id }}"
          class="create-account-section__form"
          data-custom-customer-create-form
          novalidate
        >
          <div
            id="CustomCustomerCreateMessage-{{ section.id }}"
            class="create-account-section__message"
            data-custom-customer-create-message
            role="status"
            aria-live="polite"
            hidden
          ></div>

          <div class="create-account-section__field">
            <input
              type="email"
              id="CustomCustomerCreateEmail-{{ section.id }}"
              class="create-account-section__input"
              data-custom-customer-create-email
              spellcheck="false"
              autocapitalize="off"
              autocomplete="email"
              aria-required="true"
              placeholder="{{ section.settings.email_placeholder }}"
              required
            >
          </div>

          <button
            type="submit"
            id="CustomCustomerCreateSubmit-{{ section.id }}"
            class="create-account-section__button"
            data-custom-customer-create-submit
            data-default-text="{{ section.settings.button_label | escape }}"
          >
            {{ section.settings.button_label }}
          </button>
        </form>

        {%- if section.settings.show_social_buttons -%}
          <div class="create-account-divider">
            <span class="create-account-divider__line"></span>
            <span class="create-account-divider__text">
              {{ section.settings.divider_text }}
            </span>
            <span class="create-account-divider__line"></span>
          </div>

          {%- if section.settings.helper_text != blank -%}
            <div class="create-account-section__helper-text rte">
              {{ section.settings.helper_text }}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.login_label != blank -%}
          <a class="create-account-section__login" href="{{ routes.account_login_url }}">
            {{ section.settings.login_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="create-account-section__content">
        {%- assign group_open = false -%}
        {%- assign list_open = false -%}
        {%- assign logos_open = false -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'content_heading' -%}
              {%- if list_open -%}
                </ul>
                {%- assign list_open = false -%}
              {%- endif -%}

              {%- if logos_open -%}
                </div>
                {%- assign logos_open = false -%}
              {%- endif -%}

              {%- if group_open -%}
                </div>
                {%- assign group_open = false -%}
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h2 class="create-account-section__heading" {{ block.shopify_attributes }}>
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}

            {%- when 'content_body' -%}
              {%- if list_open -%}
                </ul>
                {%- assign list_open = false -%}
              {%- endif -%}

              {%- if logos_open -%}
                </div>
                {%- assign logos_open = false -%}
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="create-account-section__body rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

            {%- when 'content_group' -%}
              {%- if list_open -%}
                </ul>
                {%- assign list_open = false -%}
              {%- endif -%}

              {%- if logos_open -%}
                </div>
                {%- assign logos_open = false -%}
              {%- endif -%}

              {%- if group_open -%}
                </div>
              {%- endif -%}

              <div class="create-account-section__group" {{ block.shopify_attributes }}>
                {%- assign group_open = true -%}

                {%- if block.settings.heading != blank -%}
                  <h3 class="create-account-section__group-heading">
                    {{ block.settings.heading }}
                  </h3>
                {%- endif -%}

            {%- when 'bullet_item' -%}
              {%- unless group_open -%}
                <div class="create-account-section__group">
                  {%- assign group_open = true -%}
              {%- endunless -%}

              {%- if logos_open -%}
                </div>
                {%- assign logos_open = false -%}
              {%- endif -%}

              {%- unless list_open -%}
                <ul class="create-account-section__list">
                {%- assign list_open = true -%}
              {%- endunless -%}

              <li class="create-account-section__list-item" {{ block.shopify_attributes }}>
                <span class="create-account-section__check" aria-hidden="true"><img src="https://cdn.shopify.com/s/files/1/0765/8304/3358/files/Checkbox_base.png?v=1779346585" alt="Checkbox"></span>
                <span>{{ block.settings.text }}</span>
              </li>

            {%- when 'logo_image' -%}
              {%- unless group_open -%}
                <div class="create-account-section__group">
                  {%- assign group_open = true -%}
              {%- endunless -%}

              {%- if list_open -%}
                </ul>
                {%- assign list_open = false -%}
              {%- endif -%}

              {%- unless logos_open -%}
                <div class="create-account-section__logos">
                {%- assign logos_open = true -%}
              {%- endunless -%}

              {%- if block.settings.logo != blank -%}
                {{
                  block.settings.logo
                  | image_url: width: 300
                  | image_tag:
                    class: 'create-account-section__logo',
                    loading: 'lazy',
                    alt: 'logo'
                }}
              {%- elsif block.settings.logo_label != blank -%}
                <span class="create-account-section__logo-text" {{ block.shopify_attributes }}>
                  {{ block.settings.logo_label }}
                </span>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}

        {%- if list_open -%}
          </ul>
        {%- endif -%}

        {%- if logos_open -%}
          </div>
        {%- endif -%}

        {%- if group_open -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
<script>

  (function () {
    let storefrontApiKey = window.global && window.global.storefrontApiKey ? window.global.storefrontApiKey : null;
    const shopDomain = {{ shop.permanent_domain | json }};
    const storefrontAccessToken = '';
    const apiVersion = '2025-10';
    const endpoint = `https://${shopDomain}/api/${apiVersion}/graphql.json`;

    const customerCreateMutation = `
      mutation customerCreate($input: CustomerCreateInput!) {
        customerCreate(input: $input) {
          customer {
            firstName
            lastName
            email
            acceptsMarketing
          }
          customerUserErrors {
            field
            message
            code
          }
        }
      }
    `;

    const customerRecoverMutation = `
      mutation customerRecover($email: String!) {
        customerRecover(email: $email) {
          customerUserErrors {
            field
            message
            code
          }
        }
      }
    `;

    const cards = document.querySelectorAll('[data-custom-customer-create-card]');

    if (!cards.length) return;

    function isValidEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function generateTemporaryPassword() {
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
      const array = new Uint32Array(32);

      if (window.crypto && window.crypto.getRandomValues) {
        window.crypto.getRandomValues(array);
      } else {
        for (let i = 0; i < array.length; i += 1) {
          array[i] = Math.floor(Math.random() * chars.length);
        }
      }

      let password = 'Aa1!';

      for (let i = 0; i < array.length; i += 1) {
        password += chars[array[i] % chars.length];
      }

      return password;
    }

    function setLoading(submitButton, isLoading) {
      const defaultText = submitButton.dataset.defaultText || 'Create customer';

      submitButton.disabled = isLoading;
      submitButton.textContent = isLoading ? 'Creating account...' : defaultText;
    }

    function showMessage(messageBox, type, message) {
      messageBox.hidden = false;
      messageBox.textContent = message;
      messageBox.classList.remove('is-success', 'is-error');
      messageBox.classList.add(type === 'success' ? 'is-success' : 'is-error');
    }

    function getCustomerErrorMessage(errors) {
      if (!errors || !errors.length) {
        return 'Something went wrong. Please try again.';
      }

      return errors.map(function (error) {
        return error.message;
      }).join(' ');
    }

    function hasCustomerErrorCode(errors, code) {
      return errors.some(function (error) {
        return error.code === code;
      });
    }

    async function sendGraphQLRequest(query, variables) {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': storefrontApiKey
        },
        body: JSON.stringify({
          query: query,
          variables: variables
        })
      });

      return response.json();
    }

    async function createCustomer(email) {
      const temporaryPassword = generateTemporaryPassword();

      return sendGraphQLRequest(customerCreateMutation, {
        input: {
          email: email,
          password: temporaryPassword,
          acceptsMarketing: false
        }
      });
    }

    async function sendPasswordSetupEmail(email) {
      return sendGraphQLRequest(customerRecoverMutation, {
        email: email
      });
    }

    cards.forEach(function (card) {
      const form = card.querySelector('[data-custom-customer-create-form]');
      const emailInput = card.querySelector('[data-custom-customer-create-email]');
      const submitButton = card.querySelector('[data-custom-customer-create-submit]');
      const messageBox = card.querySelector('[data-custom-customer-create-message]');

      if (!form || !emailInput || !submitButton || !messageBox) return;

      form.addEventListener('submit', async function (event) {
        event.preventDefault();

        const email = emailInput.value.trim();

        if (!email) {
          showMessage(messageBox, 'error', 'Please enter your email address.');
          return;
        }

        if (!isValidEmail(email)) {
          showMessage(messageBox, 'error', 'Please enter a valid email address.');
          return;
        }

        setLoading(submitButton, true);
        messageBox.hidden = true;

        try {
          const createResult = await createCustomer(email);

          const graphQLErrors = createResult?.errors || [];
          const customerCreate = createResult?.data?.customerCreate;
          const customer = customerCreate?.customer;
          const customerUserErrors = customerCreate?.customerUserErrors || [];

          if (graphQLErrors.length) {
            showMessage(messageBox, 'error', graphQLErrors[0].message || 'GraphQL request failed.');
            return;
          }

          if (customerUserErrors.length) {
            if (hasCustomerErrorCode(customerUserErrors, 'TAKEN')) {
              showMessage(
                messageBox,
                'error',
                'An account with this email already exists. Please use the login link below.'
              );
              return;
            }

            showMessage(messageBox, 'error', getCustomerErrorMessage(customerUserErrors));
            return;
          }

          if (!customer) {
            showMessage(messageBox, 'error', 'Customer could not be created. Please try again.');
            return;
          }

          await sendPasswordSetupEmail(email);

          showMessage(
            messageBox,
            'success',
            'Account created successfully. Please sign in.'
          );

          form.reset();

          /*
            Optional redirect after account creation:

            setTimeout(function () {
              window.location.href = '/pages/home-profile';
            }, 1500);
          */
        } catch (error) {
          console.error('[custom customer create failed]', error);
          showMessage(messageBox, 'error', 'Request failed. Please try again.');
        } finally {
          setLoading(submitButton, false);
        }
      });
    });
  })();
</script>
</section>

{% schema %}
{
  "name": "Create account two column",
  "class": "section-create-account-two-column",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "form_column_width",
      "min": 320,
      "max": 560,
      "step": 10,
      "unit": "px",
      "label": "Form card width",
      "default": 430
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 64
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Mobile text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_logo_alignment",
      "label": "Mobile logo alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Form card"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Sign Up For Your DAPrDAN Account"
    },
    {
      "type": "richtext",
      "id": "form_text",
      "label": "Form text",
      "default": "<p>Duis aute irure dolor in reprehenderit in voluptate velit.</p>"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit button label",
      "default": "Sign up"
    },
    {
      "type": "checkbox",
      "id": "show_social_buttons",
      "label": "Show social sign up buttons",
      "default": true
    },
    {
      "type": "text",
      "id": "divider_text",
      "label": "Divider text",
