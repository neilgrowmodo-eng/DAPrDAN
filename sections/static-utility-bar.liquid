{% style %}
  .utility-bar {
    background-color: {{ section.settings.background_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  .utility-bar .social-link,
  .utility-bar__menu-link {
    color: {{ section.settings.link_color }};
  }

  .utility-bar .disclosure__toggle {
    --disclosure-toggle-text-color: {{ section.settings.link_color }};
    --disclosure-toggle-background-color: {{ section.settings.background_color }};
  }

  .utility-bar .disclosure__toggle:hover {
    --disclosure-toggle-text-color: {{ section.settings.link_hover_color }};
  }

  .utility-bar .social-link:hover,
  .utility-bar__menu-link:hover {
    color: {{ section.settings.link_hover_color }};
  }

  .utility-bar .disclosure__toggle::after {
    --disclosure-toggle-svg-color: {{ section.settings.link_color }};
  }

  .utility-bar .disclosure__toggle:hover::after {
    --disclosure-toggle-svg-color: {{ section.settings.link_hover_color }};
  }
  .utility-bar--full-width .utility-bar__content {
    justify-content: center;
    padding-top: 0!important;
    padding-bottom: 0!important;
  }
  .utility-bar--full-width .utility-bar__content .nav-box {
    width: 100%;
    height: 40px;
    padding-top: 3px;
  }
  .collection-nav-btn {
    position: absolute;
    right: 25px; 
  }
  #mobile-nav-content-secondary {
    display: none;
  }
  @media(max-width: 1024px) {
    .shopify-section:has(.category-bar) {
      min-height: 0;
    }
    .utility-bar.category-bar {
      display: none;
    }
    #mobile-nav-content-secondary {
      display: block;
    }
    #mobile-nav-content-secondary .gm-target {
      line-height: 16px!important;
      padding: 15px 20px !important;
      height: 46px!important;
    }
  }
{% endstyle %}

<script
  type="application/json"
  data-section-type="static-utility-bar"
  data-section-id="{{ section.id }}"
  data-section-data
>
  {
    "settings": {
      "mobile_layout": {{ section.settings.mobile_layout | json }}
    }
  }
</script>


{% if section.settings.menu != blank %}
  <section
    class="
      utility-bar
      {% if section.settings.use_full_width %}
        utility-bar--full-width 
      {% endif %}
      category-bar
    "
    data-utility-bar
  >
    <div class="utility-bar__content">
      <div id="{{ section.settings.navigation_menu_id }}" class="nav-box">
        {% if section.settings.menu != blank %}
          {% for link in linklists[section.settings.menu].links %}
            <a href="{{ link.url }}" class="utility-bar__menu-link">{{ link.title }}</a>
          {% endfor %}
        {% endif %}
      </div>
      {% if section.settings.custom_button_text != blank and section.settings.custom_button_url %}
        <a href="{{ section.settings.custom_button_url }}" class="button-primary collection-nav-btn">{{ section.settings.custom_button_text }}</a>
      {% endif %}
    </div>
  </section>

  {% assign show_menu_mobile = false %}
  {% if section.settings.menu != blank and section.settings.show_menu_mobile %}
    {% assign show_menu_mobile = true %}
  {% endif %}

  {% if show_menu_mobile %}
    <div class="utility-bar__mobile" style="display: none;" data-utility-menu-mobile>
      {% comment %} {% if section.settings.mobile_layout == 'below' %}
        <span class="utility-bar__mobile__border"></span>
      {% endif %} {% endcomment %}
      {% if show_menu_mobile %}
        <div class="utility-bar__mobile-nav {% if section.settings.mobile_layout == 'below' %} utility-bar__mobile-nav--below {% endif %}" id="mobile-nav-content-secondary">
          {%
          include 'navlist',
          menu_list: linklists[section.settings.menu].links,
          depth: 1,
          max_depth: 1,
          is_mobile: true
          %}
        </div>
      {% endif %}
      {% comment %} {% if section.settings.mobile_layout == 'above' %}
        <span class="utility-bar__mobile__border"></span>
      {% endif %} {% endcomment %}
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "t:sections.utility_bar.name",
  "settings": [
    {
      "id": "use_full_width",
      "type": "checkbox",
      "label": "t:sections.utility_bar.use_full_width.label",
      "default": false
    },
    {
        "id": "navigation_menu_id",
        "type": "text",
        "label": "Navigation menu ID"
    },
    {
      "type": "header",
      "content": "t:sections.utility_bar.header_1.content"
    },
    {
      "id": "background_color",
      "type": "color",
      "label": "t:sections.utility_bar.background_color.label",
      "default": "#1b175d"
    },
    {
      "id": "link_color",
      "type": "color",
      "label": "t:sections.utility_bar.link_color.label",
      "default": "#ffffff"
    },
    {
      "id": "link_hover_color",
      "type": "color",
      "label": "t:sections.utility_bar.link_hover_color.label",
      "default": "#ffffff"
    },
    {
      "id": "border_color",
      "type": "color",
      "label": "t:sections.utility_bar.border_color.label",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "t:sections.utility_bar.header_2.content"
    },
    {
      "id": "menu",
      "type": "link_list",
      "label": "t:sections.utility_bar.menu.label"
    },
    {
      "id": "show_menu_mobile",
      "type": "checkbox",
      "label": "t:sections.utility_bar.show_menu_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.utility_bar.header_3.content"
    },
    {
      "id": "mobile_layout",
      "type": "select",
      "label": "t:sections.utility_bar.mobile_layout.label",
      "options": [
        {
          "value": "below",
          "label": "t:sections.utility_bar.mobile_layout.option_1"
        },
        {
          "value": "above",
          "label": "t:sections.utility_bar.mobile_layout.option_2"
        }
      ],
      "default": "below"
    },
    {
      "type": "header",
      "content": "Custom button"
    },
    {
      "type": "text",
      "id": "custom_button_text",
      "label": "Button text",
      "default": "Find my plan"
    },
    {
      "type": "url",
      "id": "custom_button_url",
      "label": "Button URL"
    }
  ]
}

{% endschema %}