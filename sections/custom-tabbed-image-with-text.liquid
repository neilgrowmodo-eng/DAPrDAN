{% assign section_classes = "home-section--content" %}
{% assign section_heading = section.settings.section_heading %}
{% if section_heading == blank %}
  {% assign section_classes = section_classes | append: " no-section-heading" %}
{% endif %}
{% if section.settings.custom_class != blank %}
  {% assign section_classes = section_classes | append: ' ' | append: section.settings.custom_class %}
{% endif %}

<script type="application/pxs-animation-mapping+json">
  {
    "blocks": [".tabbed-image-with-text"],
    "elements": [".tabbed-image-with-text__heading", ".tabbed-image-with-text__text", ".tabbed-image-with-text__button"]
  }
</script>

<div class="tabbed-image-with-text {{ section.settings.custom_class }}">
  {%- if section_heading != blank -%}
    <h2 class="tabbed-image-with-text__section-heading home-section--title">{{ section_heading | escape }}</h2>
  {%- endif -%}

  <div class="tabbed-image-with-text__tabs">
    {%- for block in section.blocks -%}
      <button 
        class="tabbed-image-with-text__tab-button {% if forloop.first %}active{% endif %}"
        data-tab="{{ block.id }}"
      >
        {{ block.settings.tab_title }}
      </button>
    {%- endfor -%}
  </div>

  <div class="tabbed-image-with-text__content">
    {%- for block in section.blocks -%}
      <div 
        class="tabbed-image-with-text__tab-content {% if forloop.first %}active{% endif %}"
        data-tab-content="{{ block.id }}"
      >
        <div class="tabbed-image-with-text__container {% if section.settings.image_position == 'right' %}image-right{% endif %}">
          <div class="tabbed-image-with-text__image-wrapper">
            {%- if block.settings.image != blank -%}
              {%
                render 'rimg',
                img: block.settings.image,
                size: '1500x',
                lazy: true,
                class: 'tabbed-image-with-text__image',
                focal_point: block.settings.image.presentation.focal_point,
              %}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'tabbed-image-with-text__image tabbed-image-with-text__placeholder' }}
            {%- endif -%}
          </div>
          <div class="tabbed-image-with-text__text-wrapper">
            {%- if block.settings.icon_image != blank -%}
              <div class="tabbed-image-with-text__icon-wrapper">
                {%
                  render 'rimg',
                  img: block.settings.icon_image,
                  size: '120x',
                  lazy: true,
                  class: 'tabbed-image-with-text__icon',
                %}
              </div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="tabbed-image-with-text__heading">{{ block.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="tabbed-image-with-text__text">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.checklist != blank -%}
              <div class="tabbed-image-with-text__checklist">{{ block.settings.checklist }}</div>
            {%- endif -%}
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <a href="{{ block.settings.button_link }}" class="tabbed-image-with-text__button button-primary">
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabbedSections = document.querySelectorAll('.tabbed-image-with-text');
    
    tabbedSections.forEach(section => {
      const tabButtons = section.querySelectorAll('.tabbed-image-with-text__tab-button');
      const tabContents = section.querySelectorAll('.tabbed-image-with-text__tab-content');

      function switchTab(tabId) {
        tabButtons.forEach(button => {
          button.classList.remove('active');
          if (button.dataset.tab === tabId) {
            button.classList.add('active');
          }
        });

        tabContents.forEach(content => {
          content.classList.remove('active');
          if (content.dataset.tabContent === tabId) {
            content.classList.add('active');
          }
        });
      }

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          switchTab(button.dataset.tab);
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Tabbed Image with Text",
  "class": "tabbed-image-with-text--section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Benefits Of Our Bellevue Roof Cleaning Services"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class",
      "info": "Add custom CSS class to this section"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Tab"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Main Image"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image",
          "info": "60 x 60px recommended"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Image with text"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
        },
        {
          "type": "richtext",
          "id": "checklist",
          "label": "Checklist",
          "default": "<ul><li>First checklist item</li><li>Second checklist item</li><li>Third checklist item</li></ul>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Content",
      "name": "Tabbed Image with Text",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_title": "Bellevue Environment",
            "heading": "Our Proactive Approach Ensures Optimum Roof Conditions"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Damage Prevention",
            "heading": "Prevent Costly Repairs with Regular Maintenance"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Improved Curb Appeal",
            "heading": "Enhance Your Home's Appearance"
          }
        }
      ]
    }
  ]
}
{% endschema %} 