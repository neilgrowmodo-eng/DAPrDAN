<style>
  /* Basic styling for overlay */
  .zip-popup-overlay {
    position: fixed;
    z-index: 999999; /* Ensure it stays on top */
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: none; /* Hidden by default */
    justify-content: center;
    align-items: center;
  }
  
  /* Popup modal */
  .zip-popup-modal {
    background: #fff;
    padding: 20px 30px;
    border-radius: 8px;
    width: 300px;
    max-width: 90%;
    position: relative;
    text-align: center;
  }
  
  /* Close button */
  .zip-popup-close {
    position: absolute;
    top: 15px;
    right: 15px;
    cursor: pointer;
    font-size: 20px;
  }
  
  /* Input field */
  #zipInput {
    width: 80%;
    padding: 8px;
    margin: 10px 0;
  }
  
  /* Submit button */
  #submitZip {
    padding: 10px 20px;
    cursor: pointer;
    background-color: #007ace;
    color: #fff;
    border: none;
    border-radius: 4px;
  }
</style>

<!-- ZIP Code Validator Popup -->
<div class="zip-popup-overlay" id="zipPopupOverlay">
  <div class="zip-popup-modal" id="zipPopupModal">
    <span class="zip-popup-close" id="zipPopupClose">&times;</span>
    <h2>Check Service Availability</h2>
    <p>Enter your ZIP Code to find the best service location for you.</p>
    
    <input type="text" id="zipInput" placeholder="Enter ZIP code" />
    <button id="submitZip">Check</button>
    
    <p id="zipErrorMsg" style="display: none; color: red;">
      Sorry, we don’t serve that area yet. Please try another ZIP code.
    </p>
  </div>
</div>

