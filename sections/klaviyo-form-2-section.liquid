<div class="daprdan-klaviyo-popup" data-daprdan-klaviyo-popup="{{ section.id }}">
  <div class="daprdan-klaviyo-popup__overlay" aria-hidden="true"></div>

  <div
    class="daprdan-klaviyo-popup__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="DaprdanKlaviyoPopupHeading-{{ section.id }}"
  >
    {% if section.settings.enable_close_button %}
      <button
        type="button"
        class="daprdan-klaviyo-popup__close"
        aria-label="Close popup"
        data-daprdan-popup-close
      >
        ×
      </button>
    {% endif %}

    {% if section.settings.klaviyo_background_video != blank or section.settings.klaviyo_background_image != blank %}
      <div class="daprdan-klaviyo-popup__media">
        {% if section.settings.klaviyo_background_video != blank %}
          <video autoplay muted loop playsinline class="daprdan-klaviyo-popup__video">
            <source src="{{ section.settings.klaviyo_background_video.sources[1].url }}" type="video/mp4">
          </video>
        {% elsif section.settings.klaviyo_background_image != blank %}
          <img
            src="{{ section.settings.klaviyo_background_image | image_url: width: 1600 }}"
            alt=""
            class="daprdan-klaviyo-popup__image"
            loading="lazy"
          >
        {% endif %}
      </div>
    {% endif %}

    <div class="daprdan-klaviyo-popup__content">
      <div class="daprdan-klaviyo-popup__header">
        {% if section.settings.heading != blank %}
          <h2
            id="DaprdanKlaviyoPopupHeading-{{ section.id }}"
            class="daprdan-klaviyo-popup__heading"
          >
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.sub_text != blank %}
          <div class="daprdan-klaviyo-popup__subtext rte">
            {{ section.settings.sub_text }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.body_text != blank %}
        <div class="daprdan-klaviyo-popup__body rte">
          {{ section.settings.body_text }}
        </div>
      {% endif %}

      {% if section.settings.klaviyo_shortcode != blank %}
        <div class="daprdan-klaviyo-popup__form">
          {{ section.settings.klaviyo_shortcode }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .shopify-section.Dynamic-klaviyo-section {
    display: none;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .shopify-section.Dynamic-klaviyo-section.non-serviceable {
    position: fixed !important;
    inset: 0 !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    opacity: 1 !important;
    visibility: visible;
    pointer-events: auto;
    z-index: 9999;
    padding: 24px;
  }

  .shopify-section.Dynamic-klaviyo-section.is-dismissed {
    display: none !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  .daprdan-klaviyo-popup {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .daprdan-klaviyo-popup__overlay {
    position: fixed;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    backdrop-filter: blur({{ section.settings.overlay_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.overlay_blur }}px);
    z-index: 1;
  }

  .daprdan-klaviyo-popup__dialog {
    position: relative;
    z-index: 2;
    width: min({{ section.settings.popup_width }}px, 100%);
    max-height: 90vh;
    overflow-y: auto;
    border-radius: {{ section.settings.popup_radius }}px;
    background: {{ section.settings.popup_background_color }};
    box-shadow: 0 20px 70px rgba(0, 0, 0, 0.35);
  }

  .daprdan-klaviyo-popup__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    z-index: 0;
    pointer-events: none;
  }

  .daprdan-klaviyo-popup__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: {{ section.settings.media_overlay_color }};
    opacity: {{ section.settings.media_overlay_opacity | divided_by: 100.0 }};
  }

  .daprdan-klaviyo-popup__video,
  .daprdan-klaviyo-popup__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .daprdan-klaviyo-popup__content {
    position: relative;
    z-index: 1;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    max-height: 80vh;
  }

  .daprdan-klaviyo-popup__close {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #111;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
  }

  .daprdan-klaviyo-popup__heading {
    margin: 0 0 16px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: 1.1;
    text-align: {{ section.settings.heading_alignment }};
    font-weight: 700;
    color: black;
  }

  .daprdan-klaviyo-popup__subtext {
    margin-bottom: 20px;
    color: {{ section.settings.sub_color }};
    font-size: {{ section.settings.sub_font_size_desktop }}px;
    line-height: 1.45;
    text-align: {{ section.settings.subh_alignment }};
  }

  .daprdan-klaviyo-popup__body {
    margin-bottom: 24px;
    color: {{ section.settings.body_color }};
    font-size: {{ section.settings.body_font_size_desktop }}px;
    line-height: 1.6;
    text-align: {{ section.settings.body_alignment }};
  }

  .daprdan-klaviyo-popup__body p,
  .daprdan-klaviyo-popup__subtext p {
    margin-top: 0;
  }

  .daprdan-klaviyo-popup__form,
  .daprdan-klaviyo-popup__app-blocks {
    background: {{ section.settings.form_background_color }};
    border-radius: {{ section.settings.form_radius }}px;
    overflow: hidden;
  }

  .daprdan-klaviyo-popup__app-block + .daprdan-klaviyo-popup__app-block {
    margin-top: 16px;
  }

  .daprdan-no-transition .shopify-section.Dynamic-klaviyo-section,
  .daprdan-no-transition .shopify-section.Dynamic-klaviyo-section * {
    transition: none !important;
  }

  @media (max-width: 768px) {
    .shopify-section.Dynamic-klaviyo-section.non-serviceable {
      padding: 16px;
      align-items: center;
    }

    .daprdan-klaviyo-popup__dialog {
      max-height: 88vh;
      width: 100%;
    }

    .daprdan-klaviyo-popup__content {
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }

    .daprdan-klaviyo-popup__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .daprdan-klaviyo-popup__subtext {
      font-size: {{ section.settings.sub_font_size_mobile }}px;
    }

    .daprdan-klaviyo-popup__body {
      font-size: {{ section.settings.body_font_size_mobile }}px;
    }

    .daprdan-klaviyo-popup__content {
      max-height: 70vh;
    }
  }
</style>

{% if section.settings.enable_close_button %}
  <script>
    (function () {
      const section = document.currentScript.closest('.shopify-section.Dynamic-klaviyo-section');

      if (!section) return;

      const storageKey = 'daprdan_klaviyo_popup_dismissed_{{ section.id }}';
      const closeButton = section.querySelector('[data-daprdan-popup-close]');

      try {
        if (sessionStorage.getItem(storageKey) === 'true') {
          section.classList.add('is-dismissed');
        }
      } catch (error) {}

      if (closeButton) {
        closeButton.addEventListener('click', function () {
          section.classList.add('is-dismissed');

          try {
            sessionStorage.setItem(storageKey, 'true');
          } catch (error) {}
        });
      }
    })();
  </script>
{% endif %}

