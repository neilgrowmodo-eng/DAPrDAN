    <div class="form-step-content" data-step="3">
      <div class="form-row">
        <div class="form-group">
          <label for="first-name">First Name</label>
          <input type="text" id="first-name" name="contact[first_name]" placeholder="Enter your first name" required>
        </div>
        <div class="form-group">
          <label for="last-name">Last Name</label>
          <input type="text" id="last-name" name="contact[last_name]" placeholder="Enter your last name" required>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="street-address">Street Address</label>
          <input type="text" id="street-address" name="contact[street_address]" placeholder="Enter your street address" required>
        </div>
        <div class="form-group">
          <label for="city-state">Town / City / State</label>
          <select id="city-state" name="contact[city_state]" required>
            <option value="">Select...</option>
            <option value="New York, NY">New York, NY</option>
            <option value="Los Angeles, CA">Los Angeles, CA</option>
            <option value="Chicago, IL">Chicago, IL</option>
            <option value="Houston, TX">Houston, TX</option>
            <option value="Philadelphia, PA">Philadelphia, PA</option>
            <option value="Phoenix, AZ">Phoenix, AZ</option>
            <option value="San Antonio, TX">San Antonio, TX</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="zip-code">Zip Code</label>
          <input type="number" id="zip-code" name="contact[zip_code]" placeholder="0000" required>
        </div>
        <div class="form-group">
          <label for="company-name">Company Name</label>
          <input type="text" id="company-name" name="contact[company_name]" placeholder="Enter your company name">
        </div>
      </div>
      
      <div class="form-group">
        <label for="phone-number">Phone number</label>
        <input type="tel" id="phone-number" name="contact[phone]" placeholder="Enter your phone number" required>
      </div>
      
      <div class="form-group">
        <label>Would it be okay for us to correspond with you via Text/SMS? (You must select one.)</label>
        <div class="radio-group">
          <div class="radio-item">
            <input type="radio" id="sms-yes" name="contact[sms_consent]" value="Yes" required>
            <label for="sms-yes">Yes</label>
          </div>
          <div class="radio-item">
            <input type="radio" id="sms-no" name="contact[sms_consent]" value="No">
            <label for="sms-no">No</label>
          </div>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="alternate-phone">Alternate Phone</label>
          <input type="tel" id="alternate-phone" name="contact[alternate_phone]" placeholder="Enter your phone number">
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="contact[email]" placeholder="Enter your email address" required>
        </div>
      </div>
      
      <div class="form-group">
        <label>Book a Site Visit – $97</label>
        <div class="radio-group">
          <div class="radio-item">
            <input type="radio" id="site-visit-yes" name="contact[site_visit]" value="Yes">
            <label for="site-visit-yes">Yes</label>
          </div>
          <div class="radio-item">
            <input type="radio" id="site-visit-no" name="contact[site_visit]" value="No">
            <label for="site-visit-no">No</label>
          </div>
        </div>
        <div class="site-visit-description">
          Schedule an in-person estimate with a DAPrDAN estimator. Includes a walkthrough of your property, service recommendations, and a personalized quote.
        </div>
      </div>
    </div>

    <!-- Additional Notes -->
    <div class="additional-notes">
      <h3>Additional Notes</h3>
      <textarea name="contact[body]" placeholder="Type your message..."></textarea>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="submit-button">{{ section.settings.button_text }}</button>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const formSteps = document.querySelectorAll('.form-step');
    const formStepContents = document.querySelectorAll('.form-step-content');
    
    // Initialize - show first step
    formSteps[0].classList.add('active');
    formStepContents[0].classList.add('active');
    
    // Handle step clicks
    formSteps.forEach(function(step) {
      step.addEventListener('click', function() {
        const stepNumber = this.getAttribute('data-step');
        const content = document.querySelector('.form-step-content[data-step="' + stepNumber + '"]');
        
        // Toggle active class
        this.classList.toggle('active');
        content.classList.toggle('active');
      });
    });
    
    // Form validation
    const form = document.getElementById('raq-form');
    form.addEventListener('submit', function(e) {
      let isValid = true;
      
      // Check if at least one service is selected
      const checkboxes = form.querySelectorAll('input[name="contact[services][]"]');
      const checkedBoxes = form.querySelectorAll('input[name="contact[services][]"]:checked');
      
      if (checkedBoxes.length === 0) {
        isValid = false;
        alert('Please select at least one service.');
        e.preventDefault();
        return;
      }
      
      // Check required fields
      const requiredFields = form.querySelectorAll('[required]');
      requiredFields.forEach(function(field) {
        if (!field.value.trim()) {
          isValid = false;
          field.classList.add('error');
        } else {
          field.classList.remove('error');
        }
      });
      
      // Check SMS consent radio buttons
      const smsRadios = form.querySelectorAll('input[name="contact[sms_consent]"]');
      const smsChecked = form.querySelector('input[name="contact[sms_consent]"]:checked');
      
      if (!smsChecked) {
        isValid = false;
        alert('Please select your SMS/Text preference.');
      }
      
      if (!isValid) {
        e.preventDefault();
        alert('Please fill in all required fields.');
      }
    });
  });
</script>

