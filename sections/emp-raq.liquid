<style>
  .emp-raq-section {
    max-width: 956px;
    margin: 0 auto;
    padding: 48px 20px 100px;
  }

  .emp-raq-header {
    margin-bottom: 40px;
  }

  .emp-raq-title {
    font-size: 2.5rem;
    font-weight: bold;
    color: #0A2B39;
    margin-bottom: 16px;
  }

  .emp-raq-body {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
    margin: 0 auto;
  }

  .form-step {
    background: #0A2B39;
    color: white;
    padding: 16px 24px;
    margin-bottom: 20px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
  }

  .form-step.active {
    background: #0A2B39;
  }

  .form-step-content {
    display: none;
    padding: 24px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .form-step-content.active {
    display: block;
  }

  .form-step-arrow {
    transition: transform 0.3s ease;
  }

  .form-step.active .form-step-arrow {
    transform: rotate(180deg);
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .checkbox-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #2c5f5f;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .form-group label {
    font-weight: 600;
    color: #333;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #2c5f5f;
  }

  .form-group input.error,
  .form-group select.error,
  .form-group textarea.error {
    border-color: #e74c3c;
  }

  .helper-text {
    font-size: 0.9rem;
    color: #007bff;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .radio-group {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .radio-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .radio-item input[type="radio"] {
    width: 18px;
    height: 18px;
    accent-color: #2c5f5f;
  }

  .site-visit-description {
    background: #f8f9fa;
    padding: 16px;
    border-radius: 4px;
    margin-top: 8px;
    font-size: 0.9rem;
    color: #666;
  }

  .additional-notes {
    margin: 40px 0;
  }

  .additional-notes h3 {
    text-align: center;
    color: #0A2B39;
    margin-bottom: 20px;
    font-size: 26px;
    font-style: normal;
    font-weight: 700;
    line-height: 110%;
    text-transform: capitalize;
  }

  .additional-notes textarea {
    width: 100%;
    min-height: 120px;
    padding: 16px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    resize: vertical;
  }

  .submit-button {
    background: #00A1E0;
    color: white;
    padding: 16px 32px;
    border: solid 1px #00A1E0;
    border-radius: 4px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    transition: background-color 0.3s ease;
  }

  .submit-button:hover {
    background: #00000000 !important;
    color: #00A1E0;
    border: solid 1px #00A1E0 !important;
  }

  .submit-button:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .error-message {
    color: #e74c3c;
    font-size: 0.9rem;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .emp-raq-title {
      font-size: 2rem;
    }
    
    .form-row {
      grid-template-columns: 1fr;
    }
    
    .checkbox-grid {
      grid-template-columns: 1fr;
    }
    
    .radio-group {
      flex-direction: column;
      align-items: flex-start;
    }
    .emp-raq-section {
      padding: 20px 10px 50px;
    }
  }
</style>

