<style>
  .service-video-section {
    padding: 80px 20px;
    background: #ffffff;
    text-align: center;
  }

  .service-video-section__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .service-video-section__heading {
    margin: 0 0 30px;
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: #0A2B39;
    text-align: center;
  }

  .service-video-section__text {
    margin: 0 0 50px;
    font-size: 1.125rem;
    line-height: 1.6;
    color: #666666;
    text-align: center;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .service-video-section__video-wrapper {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .service-video-section__video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .service-video-section__play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    z-index: 2;
  }

  .service-video-section__play-button:hover {
    background: rgba(255, 255, 255, 1);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .service-video-section__play-icon {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 15px 0 15px 25px;
    border-color: transparent transparent transparent #0A2B39;
    margin-left: 5px;
  }

  .service-video-section__video-container {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    background: #f4f4f4;
  }

  .service-video-section__video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-video-section__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f4f4;
    color: #999;
    font-size: 1rem;
  }

  @media screen and (max-width: 768px) {
    .service-video-section {
      padding: 60px 15px;
    }

    .service-video-section__heading {
      font-size: 2rem;
      margin-bottom: 20px;
    }

    .service-video-section__text {
      font-size: 1rem;
      margin-bottom: 40px;
    }

    .service-video-section__play-button {
      width: 60px;
      height: 60px;
    }

    .service-video-section__play-icon {
      border-width: 12px 0 12px 20px;
      margin-left: 3px;
    }
  }

  @media screen and (max-width: 480px) {
    .service-video-section__heading {
      font-size: 1.75rem;
    }

    .service-video-section__play-button {
      width: 50px;
      height: 50px;
    }

    .service-video-section__play-icon {
      border-width: 10px 0 10px 16px;
      margin-left: 2px;
    }
  }
</style>

<div class="service-video-section">
  <div class="service-video-section__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="service-video-section__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="service-video-section__text">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="service-video-section__video-wrapper">
      <div class="service-video-section__video-container" id="video-container-{{ section.id }}">
        {%- if section.settings.video != blank -%}
          {{ section.settings.video | video_tag: class: 'service-video-section__video', controls: true, preload: "metadata" }}
        {%- else -%}
          <div class="service-video-section__placeholder">
            <p>No video selected</p>
          </div>
        {%- endif -%}
        
        {%- if section.settings.video != blank -%}
          <button class="service-video-section__play-button" id="play-button-{{ section.id }}" aria-label="Play video">
            <div class="service-video-section__play-icon"></div>
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = '{{ section.id }}';
  const videoContainer = document.getElementById('video-container-' + sectionId);
  const playButton = document.getElementById('play-button-' + sectionId);
  const video = videoContainer ? videoContainer.querySelector('video') : null;

  if (video && playButton) {
    playButton.addEventListener('click', function() {
      if (video.paused) {
        video.play();
        playButton.style.display = 'none';
      } else {
        video.pause();
        playButton.style.display = 'flex';
      }
    });

    video.addEventListener('play', function() {
      playButton.style.display = 'none';
    });

    video.addEventListener('pause', function() {
      playButton.style.display = 'flex';
    });

    video.addEventListener('ended', function() {
      playButton.style.display = 'flex';
    });
  }
});
</script>

{% schema %}
{
  "name": "Service Video Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Service-Specific Video (Optional) Heading Here"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>DAPrDAN leaves no stone unturned when it comes to restoring and maintaining your home or business location. Our team handles all exterior cleaning needs from the rooftop to the driveway, leaving your property refreshed, clean, and inviting.</p>"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "This setting can be connected to a metafield with namespace 'custom' and key 'video_heading'"
    }
  ],
  "presets": [
    {
      "name": "Service Video Section",
      "settings": {
        "heading": "Service-Specific Video (Optional) Heading Here",
        "text": "<p>DAPrDAN leaves no stone unturned when it comes to restoring and maintaining your home or business location. Our team handles all exterior cleaning needs from the rooftop to the driveway, leaving your property refreshed, clean, and inviting.</p>"
      }
    }
  ]
}
{% endschema %} 